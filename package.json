{
  "name": "@kirisu2503/import-linter",
  "version": "0.1.0",
  "description": "CLI tool to detect orphan imports in React and TypeScript projects",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "import-linter": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "typescript",
    "react",
    "linter",
    "imports",
    "cli",
    "monorepo"
  ],
  "author": "Sebastian Raul Castillo Vasquez",
  "license": "MIT",
  "homepage": "https://github.com/kirisu2503/import-linter",
  "repository": {
    "type": "git",
    "url": "https://github.com/kirisu2503/import-linter.git"
  },
  "bugs": {
    "url": "https://github.com/kirisu2503/import-linter/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "fs-extra": "^11.2.0",
    "ts-morph": "^23.0.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}